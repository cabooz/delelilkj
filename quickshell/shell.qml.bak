import Quickshell
import Quickshell.Hyprland
import Quickshell.Io
import QtQuick
import QtQuick.Layouts
import "."

ShellRoot {
    id: root
    
    property int activeVdesk: 1
    property var populatedVdesks: ({})
    property var windowList: []
    property int contextVdesk: 0
    property bool popupVisible: false
    property var popupScreen: null  // Hangi ekranda popup açık
    property real popupX: 0
    property real popupY: 0
    
    // Overview state
    property bool overviewVisible: false
    property var allWindows: []  // Tüm vdesklerdeki pencereler
    property int dragSourceVdesk: 0
    property string dragWindowAddress: ""
    property string selectedWindowAddress: ""  // Seçili pencere
    property int selectedWindowVdesk: 0
    
    // IPC event listener - overview toggle için de dinle
    Connections {
        target: Hyprland
        function onRawEvent(event) {
            if (event.name === "vdesk") {
                let num = parseInt(event.data)
                if (num >= 1 && num <= 9) {
                    root.activeVdesk = num
                }
            }
            if (event.name === "openwindow" || event.name === "closewindow" || 
                event.name === "movewindow" || event.name === "workspace") {
                stateTimer.restart()
                if (root.overviewVisible) {
                    allWindowsProcess.running = true
                }
            }
            // Overview toggle için custom event
            if (event.name === "custom" && event.data === "toggleOverview") {
                root.toggleOverview()
            }
        }
    }
    
    function toggleOverview() {
        root.overviewVisible = !root.overviewVisible
        if (root.overviewVisible) {
            allWindowsProcess.running = true
            stateProcess.running = true
            console.log("Overview opened, fetching windows...")
        }
    }
    
    // Global shortcut for overview toggle
    GlobalShortcut {
        name: "toggleOverview"
        description: "Toggle Ravenholm Overview"
        
        onPressed: root.toggleOverview()
    }
    
    Timer {
        id: stateTimer
        interval: 200
        onTriggered: stateProcess.running = true
    }
    
    Process {
        id: initProcess
        command: ["sh", "-c", "hyprctl printdesk | grep -oP 'desk \\K\\d+' | head -1"]
        running: true
        
        stdout: SplitParser {
            onRead: data => {
                let num = parseInt(data.trim())
                if (num >= 1 && num <= 9) {
                    root.activeVdesk = num
                }
            }
        }
        onRunningChanged: {
            if (!running) stateProcess.running = true
        }
    }
    
    // Tüm pencereleri çek (overview için)
    Process {
        id: allWindowsProcess
        command: ["/home/rakman/.config/quickshell/scripts/get_all_windows.sh"]
        running: false
        property string buffer: ""
        
        stdout: SplitParser {
            splitMarker: ""
            onRead: data => {
                allWindowsProcess.buffer += data
            }
        }
        
        onRunningChanged: {
            if (!running && buffer.length > 0) {
                try {
                    root.allWindows = JSON.parse(buffer.trim())
                    console.log("Loaded windows:", root.allWindows.length)
                } catch(e) {
                    console.log("Parse error:", e)
                    root.allWindows = []
                }
                buffer = ""
            }
        }
    }
    
    // Pencereyi başka vdesk'e taşı
    Process {
        id: moveToVdeskProcess
        property string targetAddress: ""
        property int targetVdesk: 1
        command: ["hyprctl", "dispatch", "movetodesksilent", targetVdesk + ",address:" + targetAddress]
        running: false
        onRunningChanged: {
            if (!running) {
                console.log("Move completed: " + targetAddress + " -> vdesk " + targetVdesk)
                allWindowsProcess.running = true
                stateProcess.running = true
            }
        }
    }
    
    function moveWindowToVdesk(address, vdesk) {
        console.log("Moving window " + address + " to vdesk " + vdesk)
        moveToVdeskProcess.targetAddress = address
        moveToVdeskProcess.targetVdesk = vdesk
        moveToVdeskProcess.running = true
    }
    
    function getWindowsForVdesk(vdeskNum) {
        return allWindows.filter(w => w.vdesk === vdeskNum)
    }
    
    Process {
        id: stateProcess
        command: ["sh", "-c", "hyprctl printstate | grep -B2 'Populated: true' | grep -oP '^- \\K\\d+' | tr '\\n' ','"]
        running: false
        
        stdout: SplitParser {
            onRead: data => {
                let newPopulated = {}
                let nums = data.trim().split(',')
                for (let n of nums) {
                    let num = parseInt(n)
                    if (num >= 1 && num <= 9) {
                        newPopulated[num] = true
                    }
                }
                root.populatedVdesks = newPopulated
            }
        }
    }
    
    // Vdesk'teki pencereleri al
    Process {
        id: windowProcess
        property int targetVdesk: 0
        command: ["bash", "-c", 
            "vdesk=" + targetVdesk + "; " +
            "workspaces=$(hyprctl printstate | grep -A3 \"^- $vdesk:\" | grep \"Workspaces:\" | grep -oP '\\d+' | tr '\\n' ' '); " +
            "hyprctl clients -j | jq -c \"[.[] | select(.workspace.id as \\$w | \\\"$workspaces\\\" | split(\\\" \\\") | map(select(. != \\\"\\\") | tonumber) | index(\\$w) != null) | {address: .address, title: .title, class: .class}]\""
        ]
        running: false
        
        stdout: SplitParser {
            onRead: data => {
                try {
                    root.windowList = JSON.parse(data.trim())
                } catch(e) {
                    root.windowList = []
                }
            }
        }
    }
    
    function bringWindowHere(address) {
        Hyprland.dispatch("movetoworkspace current,address:" + address)
        Hyprland.dispatch("focuswindow address:" + address)
        root.popupVisible = false
    }
    
    function isPopulated(vdeskNum) {
        return populatedVdesks[vdeskNum] === true
    }
    
    function showWindowMenu(vdeskNum, globalX, globalY, screen) {
        if (!isPopulated(vdeskNum)) return
        root.contextVdesk = vdeskNum
        root.popupX = globalX
        root.popupY = globalY
        root.popupScreen = screen
        windowProcess.targetVdesk = vdeskNum
        windowProcess.running = true
        root.popupVisible = true
    }
    
    Variants {
        model: Quickshell.screens

        PanelWindow {
            id: bar
            
            property var modelData
            screen: modelData
            property bool hovered: false
            
            exclusionMode: ExclusionMode.Ignore
            
            anchors {
                top: true
            }
            
            margins {
                left: (screen.width - implicitWidth) / 2
            }
            
            implicitWidth: gridContainer.width + 16
            implicitHeight: gridContainer.height + 12
            color: "transparent"
            
            MouseArea {
                anchors.fill: parent
                hoverEnabled: true
                onEntered: bar.hovered = true
                onExited: bar.hovered = false
                
                Rectangle {
                    anchors.fill: parent
                    radius: Theme.radiusLarge
                    opacity: bar.hovered ? Theme.backgroundOpacity : 0
                    
                    // Paslı metal gradient
                    gradient: Gradient {
                        GradientStop { position: 0.0; color: Theme.barBackground }
                        GradientStop { position: 0.5; color: Qt.lighter(Theme.barBackground, 1.1) }
                        GradientStop { position: 1.0; color: Qt.darker(Theme.barBackground, 1.2) }
                    }
                    
                    // Üst kenar - metal parıltı
                    Rectangle {
                        anchors.top: parent.top
                        anchors.left: parent.left
                        anchors.right: parent.right
                        height: 1
                        color: Theme.lambda
                        opacity: 0.3
                    }
                    
                    Behavior on opacity {
                        NumberAnimation { duration: Theme.animFast }
                    }
                    
                    clip: true
                    
                    Grid {
                        id: gridContainer
                        anchors.horizontalCenter: parent.horizontalCenter
                        y: bar.hovered ? 6 : -height
                        columns: 3
                        rows: 3
                        spacing: Theme.spacingSmall
                        
                        Behavior on y {
                            NumberAnimation { duration: 120; easing.type: Easing.OutQuad }
                        }
                        
                        Repeater {
                            model: 9
                            
                            Rectangle {
                                id: vdeskButton
                                required property int index
                                readonly property int vdeskNum: index + 1
                                readonly property bool isActive: vdeskNum === root.activeVdesk
                                readonly property bool hasWindows: root.isPopulated(vdeskNum)
                                
                                width: 26
                                height: 26
                                radius: Theme.radiusSmall
                                
                                // Paslı metal görünümü - gradient
                                gradient: Gradient {
                                    GradientStop { position: 0.0; color: isActive ? Theme.vdeskActive : Theme.vdeskInactive }
                                    GradientStop { position: 1.0; color: isActive ? Qt.darker(Theme.vdeskActive, 1.3) : Qt.darker(Theme.vdeskInactive, 1.2) }
                                }
                                
                                // Sawblade / Lambda icon
                                Text {
                                    anchors.centerIn: parent
                                    text: vdeskButton.isActive ? Theme.lambdaSymbol : Theme.sawblade
                                    color: vdeskButton.isActive ? Theme.vdeskActiveText : Theme.vdeskInactiveText
                                    font.pixelSize: vdeskButton.isActive ? 14 : 12
                                    font.bold: true
                                    
                                    // Sawblade dönsün (aktif değilse)
                                    rotation: vdeskButton.isActive ? 0 : sawbladeRotation.angle
                                    
                                    NumberAnimation on rotation {
                                        id: sawbladeRotation
                                        property real angle: 0
                                        running: !vdeskButton.isActive && vdeskButton.hasWindows
                                        from: 0
                                        to: 360
                                        duration: 8000
                                        loops: Animation.Infinite
                                    }
                                }
                                
                                // Küçük numara köşede
                                Text {
                                    anchors.bottom: parent.bottom
                                    anchors.right: parent.right
                                    anchors.margins: 2
                                    text: vdeskButton.vdeskNum
                                    color: vdeskButton.isActive ? Theme.vdeskActiveText : Theme.textDim
                                    font.pixelSize: 8
                                    font.bold: true
                                    opacity: 0.8
                                }
                                
                                // Pencere göstergesi - headcrab yeşili
                                Rectangle {
                                    width: 6
                                    height: 6
                                    radius: 3
                                    anchors.top: parent.top
                                    anchors.left: parent.left
                                    anchors.margins: 2
                                    color: vdeskButton.hasWindows ? Theme.indicatorActive : Theme.indicatorEmpty
                                    
                                    // Glow efekti
                                    Rectangle {
                                        visible: vdeskButton.hasWindows
                                        anchors.centerIn: parent
                                        width: parent.width + 4
                                        height: parent.height + 4
                                        radius: width / 2
                                        color: Theme.indicatorActive
                                        opacity: 0.3
                                    }
                                    
                                    Behavior on color {
                                        ColorAnimation { duration: Theme.animFast }
                                    }
                                }
                                
                                MouseArea {
                                    anchors.fill: parent
                                    acceptedButtons: Qt.LeftButton | Qt.RightButton
                                    hoverEnabled: true
                                    
                                    // Hover efekti
                                    onEntered: parent.scale = 1.1
                                    onExited: parent.scale = 1.0
                                    
                                    onClicked: (mouse) => {
                                        if (mouse.button === Qt.RightButton) {
                                            let globalPos = mapToGlobal(mouse.x, mouse.y)
                                            root.showWindowMenu(vdeskButton.vdeskNum, globalPos.x, globalPos.y, bar.screen)
                                        } else {
                                            if (!vdeskButton.isActive) {
                                                Hyprland.dispatch("vdesk " + vdeskButton.vdeskNum)
                                            }
                                        }
                                    }
                                }
                                
                                Behavior on scale {
                                    NumberAnimation { duration: 100; easing.type: Easing.OutQuad }
                                }
                                
                                Behavior on color {
                                    ColorAnimation { duration: Theme.animNormal }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    
    // Pencere listesi popup - her ekran icin
    Variants {
        model: Quickshell.screens
        
        PanelWindow {
            id: windowPopup
            
            property var modelData
            screen: modelData
            
            // Sadece bu ekranda açılmışsa görünsün
            visible: root.popupVisible && root.popupScreen === modelData
            exclusionMode: ExclusionMode.Ignore
            
            anchors {
                top: true
            }
            
            // Bar'in hemen altinda, ortada
            margins {
                top: 100
                left: (screen.width - implicitWidth) / 2
            }
            
            implicitWidth: Math.max(220, windowListColumn.width + 24)
            implicitHeight: Math.min(350, windowListColumn.height + 24)
            color: "transparent"
            
            Rectangle {
                anchors.fill: parent
                opacity: Theme.backgroundOpacity
                radius: Theme.radiusMedium
                border.color: Theme.lambda
                border.width: 1
                
                // Paslı metal gradient
                gradient: Gradient {
                    GradientStop { position: 0.0; color: Theme.barBackground }
                    GradientStop { position: 1.0; color: Qt.darker(Theme.barBackground, 1.3) }
                }
                
                // Kan damlaları - sol üst
                Repeater {
                    model: 5
                    
                    Rectangle {
                        id: bloodDrop
                        required property int index
                        
                        x: 8 + index * 12 + Math.random() * 8
                        y: -2
                        width: 3 + Math.random() * 2
                        height: 0
                        radius: width / 2
                        color: Theme.blood
                        opacity: 0.8
                        
                        // Kan akış animasyonu
                        SequentialAnimation on height {
                            loops: Animation.Infinite
                            PauseAnimation { duration: index * 800 + Math.random() * 2000 }
                            NumberAnimation { 
                                from: 0
                                to: 15 + Math.random() * 25
                                duration: 1500 + Math.random() * 1000
                                easing.type: Easing.InQuad
                            }
                            PauseAnimation { duration: 3000 + Math.random() * 2000 }
                            NumberAnimation {
                                to: 0
                                duration: 800
                                easing.type: Easing.OutQuad
                            }
                        }
                    }
                }
                
                // Kan damlaları - sağ üst
                Repeater {
                    model: 4
                    
                    Rectangle {
                        id: bloodDropRight
                        required property int index
                        
                        x: parent.width - 60 + index * 14 + Math.random() * 6
                        y: -2
                        width: 2 + Math.random() * 3
                        height: 0
                        radius: width / 2
                        color: Theme.blood
                        opacity: 0.7
                        
                        SequentialAnimation on height {
                            loops: Animation.Infinite
                            PauseAnimation { duration: 1500 + index * 600 + Math.random() * 1500 }
                            NumberAnimation { 
                                from: 0
                                to: 10 + Math.random() * 20
                                duration: 1200 + Math.random() * 800
                                easing.type: Easing.InQuad
                            }
                            PauseAnimation { duration: 4000 + Math.random() * 3000 }
                            NumberAnimation {
                                to: 0
                                duration: 600
                                easing.type: Easing.OutQuad
                            }
                        }
                    }
                }
                
                // Skull header ikonu
                Text {
                    anchors.top: parent.top
                    anchors.left: parent.left
                    anchors.margins: 6
                    text: Theme.skull
                    color: Theme.blood
                    font.pixelSize: 14
                    opacity: skullPulse.opacity
                    
                    SequentialAnimation on opacity {
                        id: skullPulse
                        loops: Animation.Infinite
                        NumberAnimation { from: 0.5; to: 1.0; duration: 1500 }
                        NumberAnimation { from: 1.0; to: 0.5; duration: 1500 }
                    }
                }
                
                // Lambda turuncu üst çizgi
                Rectangle {
                    anchors.top: parent.top
                    anchors.left: parent.left
                    anchors.right: parent.right
                    anchors.leftMargin: 24
                    anchors.topMargin: 1
                    anchors.rightMargin: 1
                    height: 2
                    color: Theme.lambda
                    opacity: 0.6
                }
                
                MouseArea {
                    anchors.fill: parent
                    hoverEnabled: true
                    onExited: root.popupVisible = false
                }
                
                Column {
                    id: windowListColumn
                    anchors.centerIn: parent
                    spacing: 4
                    
                    Row {
                        spacing: 6
                        
                        Text {
                            text: Theme.skull
                            color: Theme.blood
                            font.pixelSize: 12
                        }
                        
                        Text {
                            text: "VDESK " + root.contextVdesk
                            color: Theme.lambda
                            font.pixelSize: 11
                            font.bold: true
                            font.letterSpacing: 2
                        }
                        
                        Text {
                            text: Theme.skull
                            color: Theme.blood
                            font.pixelSize: 12
                        }
                    }
                    
                    Rectangle {
                        width: 180
                        height: 1
                        gradient: Gradient {
                            orientation: Gradient.Horizontal
                            GradientStop { position: 0.0; color: "transparent" }
                            GradientStop { position: 0.3; color: Theme.blood }
                            GradientStop { position: 0.5; color: Theme.lambda }
                            GradientStop { position: 0.7; color: Theme.blood }
                            GradientStop { position: 1.0; color: "transparent" }
                        }
                    }
                    
                    Repeater {
                        model: root.windowList
                        
                        Rectangle {
                            id: windowItem
                            required property var modelData
                            required property int index
                            
                            width: 180
                            height: 28
                            radius: Theme.radiusSmall
                            color: windowMouseArea.containsMouse ? Theme.backgroundAlt : "transparent"
                            
                            Row {
                                anchors.fill: parent
                                anchors.margins: 4
                                spacing: 6
                                
                                Text {
                                    text: windowItem.modelData.class || "?"
                                    color: Theme.accent
                                    font.pixelSize: 10
                                    font.bold: true
                                    width: 50
                                    elide: Text.ElideRight
                                    anchors.verticalCenter: parent.verticalCenter
                                }
                                
                                Text {
                                    text: windowItem.modelData.title || "Untitled"
                                    color: Theme.textPrimary
                                    font.pixelSize: 10
                                    width: parent.width - 60
                                    elide: Text.ElideRight
                                    anchors.verticalCenter: parent.verticalCenter
                                }
                            }
                            
                            MouseArea {
                                id: windowMouseArea
                                anchors.fill: parent
                                hoverEnabled: true
                                onClicked: {
                                    root.bringWindowHere(windowItem.modelData.address)
                                }
                            }
                        }
                    }
                    
                    Text {
                        visible: root.windowList.length === 0
                        text: "Pencere yok"
                        color: Theme.textMuted
                        font.pixelSize: 10
                    }
                }
            }
        }
    }
    //
    // // Debug overlay
    // Variants {
    //     model: Quickshell.screens
    //
    //     PanelWindow {
    //         id: debugOverlay
    //
    //         property var modelData
    //         screen: modelData
