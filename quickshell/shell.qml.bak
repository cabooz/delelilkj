    //         implicitHeight: 50
    //         color: "transparent"
    //
    //         Rectangle {
    //             anchors.fill: parent
    //             color: Theme.debugBackground
    //             opacity: 0.9
    //             radius: Theme.radiusMedium
    //
    //             Text {
    //                 anchors.centerIn: parent
    //                 text: root.activeVdesk
    //                 color: Theme.debugText
