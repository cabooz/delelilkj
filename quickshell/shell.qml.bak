    //             }
    //         }
    //     }
    // }
    
    // ═══════════════════════════════════════════
    // OVERVIEW - Super+Tab ile açılan 3x3 grid
    // ═══════════════════════════════════════════
    Variants {
        model: Quickshell.screens
        
        PanelWindow {
            id: overviewPanel
            
            property var modelData
            screen: modelData
            
            visible: root.overviewVisible
            exclusionMode: ExclusionMode.Ignore
            
            // Tam ekran ortasında
            anchors {
                top: true
                left: true
            }
            
            margins {
                top: (screen.height - implicitHeight) / 2
                left: (screen.width - implicitWidth) / 2
            }
            
            implicitWidth: overviewGrid.width + 40
            implicitHeight: overviewGrid.height + 60
            color: "transparent"
            
            // Tıklama dışında kapatmak için
            MouseArea {
                anchors.fill: parent
                onClicked: root.overviewVisible = false
            }
            
            Rectangle {
                anchors.fill: parent
                radius: Theme.radiusMedium
                
                // Ravenholm paslı arka plan
                gradient: Gradient {
                    GradientStop { position: 0.0; color: Qt.rgba(0.15, 0.10, 0.08, 0.95) }
                    GradientStop { position: 1.0; color: Qt.rgba(0.10, 0.06, 0.04, 0.98) }
                }
                
                border.color: Theme.lambda
                border.width: 2
                
                // Üst başlık
                Rectangle {
                    id: overviewHeader
                    anchors.top: parent.top
                    anchors.left: parent.left
                    anchors.right: parent.right
                    height: 36
                    color: "transparent"
                    
                    Row {
                        anchors.centerIn: parent
                        spacing: 10
                        
                        Text {
                            text: "☠"
                            font.pixelSize: 18
                            color: Theme.blood
                        }
                        
                        Text {
                            text: "RAVENHOLM OVERVIEW"
                            font.pixelSize: 14
                            font.bold: true
                            color: Theme.lambda
                            font.letterSpacing: 2
                        }
                        
                        Text {
                            text: "☠"
                            font.pixelSize: 18
                            color: Theme.blood
                        }
                    }
                    
                    // Kan çizgisi
                    Rectangle {
                        anchors.bottom: parent.bottom
                        anchors.left: parent.left
                        anchors.right: parent.right
                        height: 2
                        gradient: Gradient {
                            orientation: Gradient.Horizontal
                            GradientStop { position: 0.0; color: "transparent" }
                            GradientStop { position: 0.3; color: Theme.blood }
                            GradientStop { position: 0.7; color: Theme.blood }
                            GradientStop { position: 1.0; color: "transparent" }
                        }
                    }
                }
                
                // 3x3 Grid
                Grid {
                    id: overviewGrid
                    anchors.top: overviewHeader.bottom
                    anchors.topMargin: 12
                    anchors.horizontalCenter: parent.horizontalCenter
                    columns: 3
                    spacing: 12
                    
                    Repeater {
                        model: 9
                        
                        Rectangle {
                            id: vdeskCell
                            required property int index
                            readonly property int vdeskNum: index + 1
                            readonly property bool isActive: vdeskNum === root.activeVdesk
                            property var cellWindows: []
                            
                            Connections {
                                target: root
                                function onAllWindowsChanged() {
                                    vdeskCell.cellWindows = root.allWindows.filter(w => w.vdesk === vdeskCell.vdeskNum)
                                    console.log("Vdesk", vdeskCell.vdeskNum, "windows:", vdeskCell.cellWindows.length)
                                }
                            }
                            
                            width: 200
                            height: 150
                            radius: Theme.radiusSmall
                            
                            // Paslı metal görünüm
                            gradient: Gradient {
                                GradientStop { position: 0.0; color: isActive ? Theme.activeBackground : Theme.cellBackground }
                                GradientStop { position: 1.0; color: isActive ? Qt.darker(Theme.activeBackground, 1.3) : Qt.darker(Theme.cellBackground, 1.2) }
                            }
                            
                            border.color: isActive ? Theme.lambda : Theme.separator
                            border.width: isActive ? 2 : 1
                            
                            // Drop zone
                            DropArea {
                                anchors.fill: parent
                                
                                onEntered: drag => {
                                    parent.border.color = Theme.indicatorColor
                                    parent.border.width = 3
                                }
                                
                                onExited: {
                                    parent.border.color = parent.isActive ? Theme.lambda : Theme.separator
                                    parent.border.width = parent.isActive ? 2 : 1
                                }
                                
                                onDropped: drop => {
                                    console.log("Drop received! address:", root.dragWindowAddress, "source:", root.dragSourceVdesk, "target:", vdeskCell.vdeskNum)
                                    if (root.dragWindowAddress && root.dragSourceVdesk !== vdeskCell.vdeskNum) {
                                        root.moveWindowToVdesk(root.dragWindowAddress, vdeskCell.vdeskNum)
                                    }
                                    parent.border.color = parent.isActive ? Theme.lambda : Theme.separator
                                    parent.border.width = parent.isActive ? 2 : 1
                                }
                            }
                            
                            // Vdesk başlığı
                            Rectangle {
                                anchors.top: parent.top
                                anchors.left: parent.left
                                anchors.right: parent.right
                                height: 24
                                color: Qt.rgba(0, 0, 0, 0.3)
                                radius: Theme.radiusSmall
                                
                                // Sadece üst köşeler yuvarlak
                                Rectangle {
                                    anchors.bottom: parent.bottom
                                    anchors.left: parent.left
                                    anchors.right: parent.right
                                    height: parent.radius
                                    color: parent.color
                                }
                                
                                Row {
                                    anchors.centerIn: parent
                                    spacing: 6
                                    
                                    Text {
                                        text: vdeskCell.isActive ? Theme.lambdaSymbol : Theme.sawblade
                                        font.pixelSize: 12
                                        color: vdeskCell.isActive ? Theme.lambda : Theme.textDim
                                    }
                                    
                                    Text {
                                        text: "VDESK " + vdeskCell.vdeskNum
                                        font.pixelSize: 10
                                        font.bold: true
                                        color: vdeskCell.isActive ? Theme.lambda : Theme.text
                                    }
                                    
                                    Text {
                                        text: "(" + vdeskCell.cellWindows.length + ")"
                                        font.pixelSize: 9
                                        color: Theme.textDim
                                    }
                                }
                            }
                            
                            // Pencere listesi
                            Column {
                                anchors.top: parent.top
                                anchors.topMargin: 28
                                anchors.left: parent.left
                                anchors.right: parent.right
                                anchors.bottom: parent.bottom
                                anchors.margins: 6
                                spacing: 4
                                clip: true
                                
                                Repeater {
                                    model: vdeskCell.cellWindows
                                    
                                    Rectangle {
                                        id: windowItem
                                        required property var modelData
                                        required property int index
                                        
                                        property bool isSelected: root.selectedWindowAddress === modelData.address
                                        
                                        width: parent.width
                                        height: 22
                                        radius: 3
                                        color: isSelected ? Theme.lambda : (windowMouse.containsMouse ? Theme.hoverBackground : Qt.rgba(0, 0, 0, 0.2))
                                        border.width: isSelected ? 2 : 0
                                        border.color: Theme.indicatorColor
                                        
                                        Row {
                                            anchors.fill: parent
                                            anchors.margins: 4
                                            spacing: 4
                                            
                                            // Program class (kitty, code, etc.)
                                            Text {
                                                id: classText
                                                text: modelData.class ? modelData.class.toLowerCase() : ""
                                                font.pixelSize: 9
                                                font.bold: true
                                                color: Theme.lambda
                                                anchors.verticalCenter: parent.verticalCenter
                                            }
                                            
                                            // Başlık (kısaltılmış)
                                            Text {
                                                width: parent.width - classText.width - 8
                                                text: {
                                                    var title = modelData.title || ""
                                                    // Eğer başlık class ile aynıysa veya boşsa gösterme
                                                    if (!title || title.toLowerCase() === modelData.class.toLowerCase()) {
                                                        return ""
                                                    }
                                                    // Kısalt
                                                    return title.length > 18 ? title.substring(0, 15) + "..." : title
                                                }
                                                font.pixelSize: 9
                                                color: Theme.textDim
                                                elide: Text.ElideRight
                                                anchors.verticalCenter: parent.verticalCenter
                                            }
                                        }
                                        
                                        MouseArea {
                                            id: windowMouse
                                            anchors.fill: parent
                                            hoverEnabled: true
                                            
                                            onClicked: {
                                                // Tek tık = seç
                                                if (root.selectedWindowAddress === modelData.address) {
                                                    // Zaten seçili, seçimi kaldır
                                                    root.selectedWindowAddress = ""
                                                    root.selectedWindowVdesk = 0
                                                } else {
                                                    root.selectedWindowAddress = modelData.address
                                                    root.selectedWindowVdesk = vdeskCell.vdeskNum
                                                    console.log("Window selected:", modelData.address, "from vdesk", vdeskCell.vdeskNum)
                                                }
                                            }
                                            
                                            onDoubleClicked: {
                                                // Çift tıkla o pencereye git
                                                Hyprland.dispatch("vdesk " + vdeskCell.vdeskNum)
                                                Hyprland.dispatch("focuswindow address:" + modelData.address)
                                                root.overviewVisible = false
                                            }
                                        }
                                    }
                                }
                                
                                // Boş vdesk
                                Text {
                                    visible: vdeskCell.cellWindows.length === 0
                                    text: "— boş —"
                                    font.pixelSize: 10
                                    font.italic: true
                                    color: Theme.textDim
                                    anchors.horizontalCenter: parent.horizontalCenter
                                }
                            }
                            
                            // Tıklayınca o vdesk'e git VEYA seçili pencereyi taşı
                            MouseArea {
                                anchors.fill: parent
                                z: -1
                                onClicked: {
                                    if (root.selectedWindowAddress && root.selectedWindowVdesk !== vdeskCell.vdeskNum) {
                                        // Seçili pencere var ve farklı vdesk'e tıklandı - taşı
                                        console.log("Moving", root.selectedWindowAddress, "from", root.selectedWindowVdesk, "to", vdeskCell.vdeskNum)
                                        root.moveWindowToVdesk(root.selectedWindowAddress, vdeskCell.vdeskNum)
                                        root.selectedWindowAddress = ""
                                        root.selectedWindowVdesk = 0
                                    } else if (!root.selectedWindowAddress && !vdeskCell.isActive) {
                                        // Seçili pencere yok ve aktif vdesk DEĞİL - o vdesk'e git
                                        Hyprland.dispatch("vdesk " + vdeskCell.vdeskNum)
                                        root.overviewVisible = false
                                    } else if (root.selectedWindowAddress) {
                                        // Seçili pencere var ama aynı vdesk'e tıklandı - seçimi kaldır
                                        root.selectedWindowAddress = ""
                                        root.selectedWindowVdesk = 0
                                    }
                                    // Aktif vdesk'e tıklandıysa ve seçili pencere yoksa - hiçbir şey yapma
                                }
                            }
                        }
                    }
                }
                
                // Alt bilgi
                Text {
                    anchors.bottom: parent.bottom
                    anchors.horizontalCenter: parent.horizontalCenter
                    anchors.bottomMargin: 8
                    text: root.selectedWindowAddress ? "📦 Pencere seçili - Hedef vdesk'e tıkla" : "Tık = Seç | Çift Tık = Git | ESC = Kapat"
                    font.pixelSize: 9
                    color: root.selectedWindowAddress ? Theme.lambda : Theme.textDim
                }
            }
            
            // ESC ile kapat
            Shortcut {
                sequence: "Escape"
                onActivated: root.overviewVisible = false
            }
        }
    }
}
